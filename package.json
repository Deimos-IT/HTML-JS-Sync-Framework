{
  "name": "fwitd",
  "publisher": "ITD",
  "displayName": "FWITD",
  "description": "watch FW components",
  "version": "0.0.1",
  "icon": "images/fw_settings.png",
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:html"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "fwitd.helloWorld",
        "title": "Hello World"
      },
      {
        "command": "fwAttributes.openLiveUiBuilder",
        "title": "Open Live UiBuilder"
      },
      {
        "command": "fwAttributes.openUiBuilderComponentInitializer",
        "title": "Open UiBuilder FWComponent Initializer"
      }
    ],
    "languages": [
      {
        "id": "html",
        "aliases": [
          "HTML",
          "html"
        ],
        "extensions": [
          ".html",
          ".htm"
        ]
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "fwAttributes.openLiveUiBuilder",
          "when": "resourceLangId == html",
          "group": "navigation"
        }
      ],
      "explorer/context": [
        {
          "command": "fwAttributes.openLiveUiBuilder",
          "when": "resourceLangId == html",
          "group": "navigation"
        },
        {
          "command": "fwAttributes.openUiBuilderComponentInitializer",
          "when": "explorerResourceIsFolder && resourceFilename == App",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.13",
    "@types/vscode": "^1.109.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}